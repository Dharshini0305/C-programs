# include <stdio.h>
long factorial(int num){
	long fact=1;
	int i;
	for(i=1;i<=num;i++){
		fact=fact*i;
	}
	return fact;
}

int main(){
	int n;
	printf("Enter the number:");
	scanf("%d",&n);
	if(n<0){
		printf("The factorial of the given number does not exist");
	}
	else{
		printf("The factorial of the given number is %d",factorial(n));
	}
	return 0;
}
